# ============================================================
# Spring Slumber Server - Environment Variables Template
# ============================================================
# 加载优先级（高 → 低）：
#   1) 进程环境变量（部署平台/Shell 注入）
#   2) .env.{APP_ENV}  环境特定文件
#   3) .env           通用兜底
#
# 多环境使用：
#   cp .env.example .env.development && 编辑
#   cp .env.example .env.production  && 编辑
#   cp .env.example .env.test        && 编辑
#
# 切换环境：
#   APP_ENV=development  go run ./cmd/server
#   APP_ENV=production   go run ./cmd/server
#   APP_ENV=test         go test ./...
# ============================================================

# ---------------- HTTP ----------------
HTTP_HOST=0.0.0.0
HTTP_PORT=8080
HTTP_READ_TIMEOUT=5s
HTTP_WRITE_TIMEOUT=10s
HTTP_IDLE_TIMEOUT=60s

# ---------------- CORS ----------------
# 多个来源使用英文逗号分隔，* 表示全部放行（仅限开发/测试）
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# 默认不允许携带凭据；需要时切换为 true，并把 ORIGINS 写为具体来源。
CORS_ALLOW_CREDENTIALS=false
# 允许的请求方法（OPTIONS 预检需要）
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
# 允许的请求头：含前端可能使用的所有自定义 header
CORS_ALLOWED_HEADERS=Authorization,Content-Type,Accept,Accept-Language,Origin,X-Requested-With,X-Request-ID,x-spring-slumber-locale
# 暴露给前端的响应头
CORS_EXPOSED_HEADERS=X-Request-ID
CORS_MAX_AGE=5m

# ---------------- Postgres ----------------
# 方式一：完整 DSN（优先）
# DATABASE_URL=postgres://user:password@localhost:5432/spring_slumber?sslmode=disable&timezone=Asia/Shanghai

# 方式二：拆分字段
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=spring_slumber
POSTGRES_SSLMODE=disable
POSTGRES_TIMEZONE=Asia/Shanghai

POSTGRES_MAX_OPEN_CONNS=25
POSTGRES_MAX_IDLE_CONNS=5
POSTGRES_CONN_MAX_LIFETIME=30m
POSTGRES_CONN_MAX_IDLE_TIME=5m
