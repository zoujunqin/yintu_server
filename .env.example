# ============================================================
# Spring Slumber Server - Environment Variables Template
# ============================================================
# 加载优先级（高 → 低）：
#   1) 进程环境变量（部署平台/Shell 注入）
#   2) .env.{APP_ENV}  环境特定文件
#   3) .env           通用兜底
#
# 多环境使用：
#   cp .env.example .env.development && 编辑
#   cp .env.example .env.production  && 编辑
#   cp .env.example .env.test        && 编辑
#
# 切换环境：
#   APP_ENV=development  go run ./cmd/server
#   APP_ENV=production   go run ./cmd/server
#   APP_ENV=test         go test ./...
# ============================================================

APP_NAME=spring-slumber-server
APP_ENV=development
APP_VERSION=dev

# ---------------- HTTP ----------------
HTTP_HOST=0.0.0.0
HTTP_PORT=8080
HTTP_READ_TIMEOUT=5s
HTTP_WRITE_TIMEOUT=10s
HTTP_IDLE_TIMEOUT=60s

# ---------------- CORS ----------------
# 多个来源使用英文逗号分隔，* 表示全部放行（仅限开发/测试）
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---------------- Postgres ----------------
# 方式一：完整 DSN（优先）
# DATABASE_URL=postgres://user:password@localhost:5432/spring_slumber?sslmode=disable&timezone=Asia/Shanghai

# 方式二：拆分字段
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=spring_slumber
POSTGRES_SSLMODE=disable
POSTGRES_TIMEZONE=Asia/Shanghai

POSTGRES_MAX_OPEN_CONNS=25
POSTGRES_MAX_IDLE_CONNS=5
POSTGRES_CONN_MAX_LIFETIME=30m
POSTGRES_CONN_MAX_IDLE_TIME=5m

# ---------------- JWT ----------------
JWT_SECRET=change-me-in-production
JWT_ISSUER=spring-slumber-server
JWT_EXPIRES_IN=2h

# ---------------- 登录 & 风控 ----------------
AUTH_CODE_TTL=5m
AUTH_CODE_SALT=spring-slumber-code-salt
AUTH_SEND_COOLDOWN=1m
AUTH_LOGIN_IP_LIMIT=5
AUTH_LOGIN_IP_WINDOW=1m
AUTH_MAX_VERIFY_ATTEMPTS=5
AUTH_LOCK_DURATION=10m

# ---------------- 短信下发 ----------------
SMS_PROVIDER=mock
SMS_API_KEY=
SMS_API_SECRET=
SMS_SIGN_NAME=
SMS_TEMPLATE_ID=
